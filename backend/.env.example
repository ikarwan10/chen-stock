# Chen's Stocks — Backend Environment Variables
# Copy this file to .env and fill in values

# Database URL — PostgreSQL (Render provides this automatically)
# Local dev: postgresql://localhost/chen_stocks
# Render: set via Render dashboard (auto-injected from managed PostgreSQL)
DATABASE_URL=postgresql://localhost/chen_stocks

# Alpha Vantage API key (fallback provider — get free key at alphavantage.co)
ALPHA_VANTAGE_API_KEY=

# Quote cache TTL in seconds (default: 60)
QUOTE_CACHE_TTL=60

# Frontend URL for CORS (set to your Render static site URL in production)
FRONTEND_URL=http://localhost:5173
